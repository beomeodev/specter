{
  "permissions": {
    "allow": [
      "SlashCommand(/speckit.tasks)",
      "Bash(.specify/scripts/bash/check-prerequisites.sh:*)",
      "Bash(awk:*)",
      "SlashCommand(/speckit.analyze)",
      "Bash(git --version:*)",
      "Bash(mkdir:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(pytest:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(xargs:*)",
      "SlashCommand(/ms.up-docs --docs=dev)",
      "Bash(if [ -f .pre-commit-config.yaml ])",
      "Bash(then echo \"Pre-commit config exists\")",
      "Bash(else echo \"No pre-commit config found\")",
      "Bash(fi)",
      "Bash(git add:*)",
      "Bash(then pre-commit run --all-files)",
      "Bash(else echo \"No pre-commit hooks to run\")"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "cli-bridge",
    "context7"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ms/ms_hooks.py SessionStart"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ms/ms_hooks.py SessionEnd"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ms/ms_hooks.py UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ms/ms_hooks.py PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ms/ms_hooks.py PostToolUse"
          }
        ]
      }
    ]
  }
}
