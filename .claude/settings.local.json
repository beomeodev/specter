{
  "permissions": {
    "allow": [
      "Bash(.specify/scripts/bash/check-prerequisites.sh:*)",
      "Bash(if [ -d \"/workspace/my-spec/specs/001-my-spec-spec/checklists\" ])",
      "Bash(then echo \"EXISTS\")",
      "Bash(else echo \"NOT_EXISTS\")",
      "Bash(fi)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(npm search @anthropics/cli-bridge-mcp)",
      "Bash(git add:*)",
      "Bash(if [ -f .pre-commit-config.yaml ])",
      "Bash(then)",
      "Bash(pre-commit run:*)",
      "Read(//tmp/**)",
      "Bash(docker compose:*)",
      "Bash(tee:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.facefusion.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git config --global push.autoSetupRemote true)",
      "WebSearch",
      "Bash(then pre-commit run --all-files)"
