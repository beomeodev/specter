    "ms-foundation-constitution": {
      "type": "guardrail",
      "priority": "critical",
      "enforcement": "suggest",
      "description": "Constitution compliance validator (≤500 SLOC, ≤10 complexity)",
      "promptTriggers": {
        "keywords": [
          "file size",
          "complexity",
          "SLOC",
          "constitution",
          "file too large",
          "refactor large file",
          "split file"
        ],
        "intentPatterns": [
          "(check|verify|validate).*?constitution",
          "file.*?(too|very).*?(large|big)",
          "(reduce|lower).*?complexity",
          "McCabe.*?complexity"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [],
        "contentPatterns": []
      }
    },
