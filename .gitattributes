# 기본 텍스트 파일 자동 처리
* text=auto

# ===== 줄바꿈 설정 =====
# 소스 코드 - 항상 LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.java text eol=lf
*.php text eol=lf
*.rb text eol=lf
*.go text eol=lf
*.rs text eol=lf

# 웹 파일 - 항상 LF
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 셸 스크립트 - 항상 LF
*.sh text eol=lf
*.bash text eol=lf
Makefile text eol=lf

# Windows 배치 파일 - 항상 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 문서 - 항상 LF
*.md text eol=lf
*.txt text eol=lf
README text eol=lf
LICENSE text eol=lf

# ===== 바이너리 파일 =====
# 이미지
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary

# 폰트
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# 문서
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# 압축 파일
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

# 실행 파일
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# ===== Git LFS 설정 (대용량 파일) =====
# 이미지 원본
*.psd filter=lfs diff=lfs merge=lfs -text
*.ai filter=lfs diff=lfs merge=lfs -text
*.sketch filter=lfs diff=lfs merge=lfs -text

# 비디오
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text

# 오디오
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text

# 데이터베이스
*.db filter=lfs diff=lfs merge=lfs -text
*.sqlite filter=lfs diff=lfs merge=lfs -text

# 대용량 데이터
*.csv filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text